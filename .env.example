# =========================================================================
#  DULEME OS — variables d'environnement (MODÈLE)
#  Copiez ce fichier en `.env.local` et renseignez les valeurs réelles.
#  NE JAMAIS committer `.env.local` ni de vraie clé. Ce fichier reste vide.
# =========================================================================

# --- Base de données (Supabase / PostgreSQL, région EU) ---
# DATABASE_URL : connexion « pooler » (mode transaction, port 6543) — utilisée par l'app.
#   Récupérée dans Supabase : Project Settings → Database → Connection string → "Transaction" (URI).
DATABASE_URL=
# DIRECT_URL : connexion directe (port 5432) — utilisée UNIQUEMENT pour les migrations.
DIRECT_URL=

# --- Supabase (Auth & Storage — activés au sprint Back Office / Espace Client) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Connecteurs externes (tous dégradables : vide = connecteur inactif) ---
# Brevo (emails / notifications / newsletter)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=contact@dulemeandcie.com
BREVO_SENDER_NAME=DULEME AND CIE
# Email interne qui reçoit les alertes (nouvelle demande, nouveau message)
NOTIFY_EMAIL=inpulsecaraibes@gmail.com

# Sinao (devis / factures) — RÉGÉNÉRER la clé (l'ancienne a été exposée)
SINAO_API_KEY=
SINAO_API_BASE=

# Fireflies (comptes-rendus de RDV)
FIREFLIES_API_KEY=

# Google (Drive + Agenda + Meet) — un seul compte : celui du cabinet
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_DRIVE_ROOT=DULEME

# --- IA (abstraction : OpenAI ou Anthropic) ---
AI_PROVIDER=anthropic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Back Office (accès admin) ---
# Généré dans .env.local par : node scripts/setup-admin.mjs
ADMIN_EMAIL=
ADMIN_PASSWORD=
AUTH_SECRET=
